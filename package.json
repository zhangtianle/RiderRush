{
  "name": "riderrush",
  "version": "0.8.0-alpha",
  "description": "RiderRush 外卖冲冲冲 - 路径解谜休闲游戏",
  "main": "src/main.ts",
  "scripts": {
    "build:web": "esbuild src/web-entry.ts --bundle --outfile=web/dist/web.bundle.js --format=iife --platform=browser --target=es2015 --loader:.json=json",
    "watch:web": "esbuild src/web-entry.ts --bundle --outfile=web/dist/web.bundle.js --format=iife --platform=browser --target=es2015 --loader:.json=json --watch",
    "serve:web": "cd web && python3 -m http.server 8080",
    "dev:web": "npm run build:web && npm run serve:web",
    "test": "ts-node src/tests/CoreTests.ts"
  },
  "keywords": [
    "game",
    "minigame",
    "wechat",
    "puzzle",
    "delivery"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:zhangtianle/RiderRush.git"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
